rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    function isChurchAdmin(churchId) {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'church_admin' && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.churchId == churchId;
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (isAdmin() || request.auth.uid == userId || (resource != null && isChurchAdmin(resource.data.churchId)));
      allow create: if isAuthenticated() && (request.auth.uid == userId || isAdmin() || isChurchAdmin(request.resource.data.churchId));
      allow update: if isAuthenticated() && (isAdmin() || request.auth.uid == userId);
      allow delete: if isAdmin();
    }
    
    match /churches/{churchId} {
      allow list: if true;
      allow get: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    match /services/{serviceId} {
      allow list: if true;
      allow get: if isAuthenticated();
      allow write: if isAdmin() || isChurchAdmin(resource.data.churchId);
    }

    match /ministers/{ministerId} {
      allow list: if true;
      allow get: if isAuthenticated();
      allow write: if isAdmin() || isChurchAdmin(resource.data.churchId);
    }

    match /announcements/{announcementId} {
      allow list: if true;
      allow get: if isAuthenticated();
      allow write: if isAdmin() || isChurchAdmin(resource.data.churchId);
    }

    match /livestreams/{livestreamId} {
      allow list: if true;
      allow get: if isAuthenticated();
      allow write: if isAdmin() || isChurchAdmin(resource.data.churchId);
    }

    match /members/{memberId} {
      allow read: if isAuthenticated() && (isAdmin() || isChurchAdmin(resource.data.churchId));
      allow write: if isAdmin() || isChurchAdmin(resource.data.churchId);
    }
    
    match /config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
